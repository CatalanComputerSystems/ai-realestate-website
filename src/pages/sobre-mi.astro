---
import MainLayout from '../components/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
import { agent } from '../data/agent';
import { credentials } from '../data/credentials';
import { testimonials } from '../data/testimonials';
import { breadcrumbSchema, personSchema } from '../lib/seo';
---
<MainLayout {...site.seo.about} schema={[personSchema(), breadcrumbSchema('Sobre mí', '/sobre-mi')]}>
  <section class="bg-sand py-16">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div class="card overflow-hidden">
        <img src={agent.image} alt={`Foto de ${agent.name}`} width="400" height="400" class="h-full w-full object-cover" />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-500">Sobre mí</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">Hola, soy {agent.name} — Agente Inmobiliaria en Asunción</h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">{agent.longBio}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          {agent.specialties.map((item) => <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-700">{item}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <SectionHeading eyebrow="En qué me enfoco" title="Experiencia local, criterio comercial y seguimiento real" description="La idea es que cada consulta avance con menos ruido y mejores decisiones." />
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {credentials.map((credential) => (
          <div class="card p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-500">{credential.label}</p>
            <p class="mt-3 text-slate-700">{credential.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-slate-50">
    <div class="container-shell">
      <SectionHeading eyebrow="Resultados" title="Lo que valoran mis clientes" description="Comunicación clara, timing rápido y selección más precisa de oportunidades." />
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((testimonial) => <TestimonialCard testimonial={testimonial} />)}
      </div>
    </div>
  </section>

  <section class="section-pad bg-slate-950 text-white">
    <div class="container-shell flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Siguiente paso</p>
        <h2 class="mt-3 text-3xl font-bold">Si querés comprar, vender o alquilar en Asunción, hablemos.</h2>
      </div>
      <div class="flex flex-wrap gap-4">
        <Button href="/contacto">Hablemos</Button>
        <Button href="/propiedades" variant="ghost">Ver mis propiedades</Button>
      </div>
    </div>
  </section>
</MainLayout>
