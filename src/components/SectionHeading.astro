---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, description, align = 'left' } = Astro.props;
---
<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-brand-500">{eyebrow}</p>}
  <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-lg leading-8 text-slate-600">{description}</p>}
</div>
