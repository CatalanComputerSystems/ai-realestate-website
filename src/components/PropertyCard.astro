---
import type { Listing } from '../types/content';
import { contact } from '../data/contact';
const { listing } = Astro.props as { listing: Listing };
---
<article class="card overflow-hidden">
  <img src={listing.image} alt={listing.title} width="800" height="600" loading="lazy" class="h-56 w-full object-cover" />
  <div class="p-6">
    <div class="mb-3 flex flex-wrap gap-2">
      <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{listing.operation}</span>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">{listing.zone}</span>
    </div>
    <h3 class="text-xl font-semibold text-slate-900">{listing.title}</h3>
    <p class="mt-2 text-sm text-slate-600">{listing.description}</p>
    <p class="mt-4 text-lg font-bold text-slate-900">{listing.price}</p>
    <ul class="mt-4 flex flex-wrap gap-2">
      {listing.badges.map((badge) => <li class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-700">{badge}</li>)}
    </ul>
    <a href={contact.whatsappUrl} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex rounded-full bg-brand-500 px-4 py-3 text-sm font-semibold text-white">Consultar por WhatsApp</a>
  </div>
</article>
