---
import { site } from '../data/site';
import { contact } from '../data/contact';
---
<footer class="border-t border-slate-200 bg-slate-950 text-slate-200">
  <div class="container-shell grid gap-8 py-12 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <p class="text-xl font-semibold">{site.agentName}</p>
      <p class="mt-3 max-w-md text-sm leading-7 text-slate-400">Agente inmobiliaria para compra, venta y alquiler en Asunción. Atención rápida por WhatsApp, teléfono y formulario.</p>
      <p class="mt-4 text-sm text-slate-400">NAP: {site.agentName} · {contact.addressLabel} · {contact.phone}</p>
    </div>
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Mapa del sitio</p>
      <ul class="mt-4 space-y-3 text-sm">
        {site.nav.map((link) => (
          <li><a href={link.href} class="hover:text-white">{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Contacto</p>
      <ul class="mt-4 space-y-3 text-sm">
        <li><a href={contact.whatsappUrl} rel="noopener noreferrer" target="_blank" class="hover:text-white">WhatsApp</a></li>
        <li><a href={contact.phoneUrl} class="hover:text-white">Llamar</a></li>
        <li><a href={`mailto:${contact.email}`} class="hover:text-white">{contact.email}</a></li>
      </ul>
    </div>
  </div>
</footer>
